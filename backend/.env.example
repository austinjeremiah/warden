# ===== WARDEN (Provider on Order A + Requester on Order B) =====
CROO_API_KEY=croo_sk_xxx
WARDEN_AA_WALLET=0xWardenAaWallet
WARDEN_SERVICE_ID=svc-xxx

# ===== CROO endpoints (shared) =====
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# ===== Groq (quality gate + demo providers) =====
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Demo Provider A (good path) =====
PROVIDER_A_API_KEY=croo_sk_xxx
PROVIDER_A_AA_WALLET=0x...
PROVIDER_A_SERVICE_ID=svc-xxx

# ===== Demo Provider B (bad path demo) =====
PROVIDER_B_API_KEY=croo_sk_xxx
PROVIDER_B_AA_WALLET=0x...
PROVIDER_B_SERVICE_ID=svc-xxx
FORCE_BAD_OUTPUT=true

# ===== Demo Buyer (Requester on Order A) =====
BUYER_API_KEY=croo_sk_xxx
BUYER_AA_WALLET=0x...
